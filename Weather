<!DOCTYPE html>
<html>
<head>
<title>Async Weather Tracker</title>
<style>*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, sans-serif;
}

body{
height:100vh;
background:linear-gradient(to right,#7490eb,#e62a00);
display:flex;
justify-content:center;
align-items:center;
}

.container{
background:rgb(143, 173, 255);
padding:35px;
width:380px;
border-radius:15px;
box-shadow: 10px 15px 10px rgba(0,0,0,0.2);
text-align:center;
height: 500px;
transition: all 0.5s ease;
}
.container:hover{
    box-shadow: 20px 20px 25px 20px  rgb(103, 103, 247);
}

h1{
margin-bottom:20px;
color:#333;
}

.search-box{
margin-bottom:20px;
}

input{
padding:10px;
width:300px;
border-radius:8px;
border:1px solid #ccc;
outline:none;
font-size:14px;
cursor: pointer;
}

button{
padding:20px;
border:none;
background:#00a189;
color:white;
border-radius:8px;
cursor:pointer;
font-size:14px;
transition:all 0.9s ease;
margin-top: 20px;
}

button:hover{
background:#000000;
transform:rotateX(30deg);
box-shadow: 2px 10px 15px black;
}

#loading{
color:orange;
margin-top:10px;
}

#result{
margin-top:15px;
font-size:18px;
color:#333;
}

h3{
margin-top:25px;
margin-bottom:10px;
}

ul{
list-style:none;
}

li{
background:#f2f2f2;
margin:5px 0;
padding:8px;
border-radius:6px;
}</style>
</head>

<body>

<div class="container">

<h1>🌩️ Async Weather Tracker</h1>

<div class="search-box">
<input type="text" id="cityInput" placeholder="Enter city name">
<button onclick="getWeather()">Get Weather</button>
</div>

<p id="loading"></p>

<div id="result"></div>

<h3>Search History</h3>

<ul id="history"></ul>

<button class="clear-btn" onclick="clearHistory()">Clear History</button>

</div>

